# Web service
PUBLIC_APP_BASE_URL=http://localhost:3000
AUTOMATION_STORAGE_ADAPTER=local-json
AUTOMATION_REPOSITORY_ADAPTER=local-json
AUTOMATION_DATA_DIR=./data
WORKER_API_SECRET=
COMMERCE_AUTOMATION_API_SECRET=
# Server-only Supabase/Postgres repository adapter. Never use NEXT_PUBLIC_ for service role keys.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Local smoke only. Leave unset in normal production deployments.
ENABLE_MOCK_STORAGE_ROUTE=
# Development API routes (/api/dev/seed, reset-storage, reset-settings) are disabled in production unless explicitly enabled.
# Leave unset or false for normal production.
ENABLE_DEV_TOOLS=

# Legacy/optional n8n. next-batch video rendering now uses worker_jobs, not n8n.
N8N_NIGHTLY_SCOUT_WEBHOOK_URL=
N8N_NEXT_BATCH_WEBHOOK_URL=
N8N_RETRY_ITEM_WEBHOOK_URL=
N8N_HOLD_ITEM_WEBHOOK_URL=
N8N_SKIP_ITEM_WEBHOOK_URL=
N8N_WEBHOOK_SECRET=

# Python Worker
WEB_APP_BASE_URL=http://localhost:3000
WORKER_ID=local-python-worker
WORKER_JOB_TYPES=video_render,sheet_sync
STORAGE_BACKEND=local
LOCAL_STORAGE_BASE_DIR=./outputs/storage
STORAGE_LOCAL_BASE_URL=http://localhost:3000/mock-storage
PUBLIC_STORAGE_BASE_URL=http://localhost:3000/mock-storage

# S3/R2/Supabase-compatible storage
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto
# Supabase Storage S3 protocol aliases. Use generated storage access keys, not the DB service role key.
SUPABASE_STORAGE_ENDPOINT_URL=
SUPABASE_STORAGE_ACCESS_KEY_ID=
SUPABASE_STORAGE_SECRET_ACCESS_KEY=
SUPABASE_STORAGE_REGION=
SUPABASE_STORAGE_PUBLIC_BASE_URL=
# Cloudflare R2 aliases.
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
# Bucket-specific R2 Public Development URLs. Keep bucket names unchanged.
R2_PUBLIC_BASE_URL_RENDERED_VIDEOS=
R2_PUBLIC_BASE_URL_THUMBNAILS=
R2_PUBLIC_BASE_URL_SUBTITLES=
R2_PUBLIC_BASE_URL_UPLOAD_PACKAGES=
# Optional fallback only. Prefer the bucket-specific values above for 4-bucket R2 smoke.
R2_PUBLIC_BASE_URL=

# Optional server-only Coupang Partners product source. Leave unset unless running approved live scout gates.
COUPANG_PARTNERS_PROVIDER_ENABLED=false
COUPANG_PARTNERS_BASE_URL=https://api-gateway.coupang.com
COUPANG_PARTNERS_ACCESS_KEY=
COUPANG_PARTNERS_SECRET_KEY=
COUPANG_CUSTOMER_ID=
COUPANG_PARTNER_ID=
COUPANG_PARTNERS_CUSTOMER_ID=
# Legacy optional collector credential aliases. Prefer the COUPANG_PARTNERS_* names above.
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=

# Optional server-only content AI provider scaffold. Default is template fallback.
# Live OpenAI/Gemini calls are not part of the current production path.
CONTENT_AI_PROVIDER=template
OPENAI_API_KEY=
GEMINI_API_KEY=

# Optional local-only motion provider scaffold. Disabled by default; live execution requires a separate approval.
COMFYUI_WAN_I2V_ENABLED=false
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WAN_I2V_WORKFLOW_PATH=./config/comfyui/wan-i2v.workflow.example.json
COMFYUI_WAN_I2V_TIMEOUT_MS=600000
COMFYUI_WAN_I2V_POLL_INTERVAL_MS=2000
COMFYUI_WAN_I2V_OUTPUT_DIR=commerce-assets/generated-motion

# Optional cloud image-to-video adapter scaffold. Disabled by default; paid execution requires separate approval.
FAL_KLING_I2V_ENABLED=false
FAL_KLING_I2V_COST_APPROVED=false
FAL_API_KEY=replace-with-fal-api-key
FAL_KLING_I2V_MODEL_ID=replace-with-current-fal-kling-image-to-video-model-id
FAL_KLING_I2V_TIMEOUT_MS=900000
FAL_KLING_I2V_POLL_INTERVAL_MS=3000
FAL_KLING_I2V_OUTPUT_DIR=commerce-assets/generated-motion

# Optional local-only ASR provider for Shorts voice review. Keep models/venvs outside this repo.
LOCAL_ASR_ENABLED=
LOCAL_ASR_PROVIDER=
LOCAL_ASR_COMMAND=
LOCAL_ASR_MODEL_PATH=
LOCAL_ASR_LANGUAGE=ko
LOCAL_ASR_MIN_TRANSCRIPT_SIMILARITY=0.82
LOCAL_ASR_MIN_CONTEXT_ANCHORS=3
LOCAL_ASR_MIN_WPM=130
LOCAL_ASR_MAX_WPM=160

# Optional YouTube private upload readiness indicators only. Keep values server-only.
# Public upload remains blocked unless PUBLIC_UPLOAD_ENABLED is explicitly true.
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=
YOUTUBE_TOKEN_PROVIDER=
YOUTUBE_TOKEN_PROVIDER_MODE=
YOUTUBE_LOCAL_TOKEN_FILE_PATH=
YOUTUBE_TOKEN_FILE=
YOUTUBE_TOKEN_READY=
YOUTUBE_SCOPES_READY=
YOUTUBE_QUOTA_READY=
YOUTUBE_ACCOUNT_READY=
YOUTUBE_POLICY_READY=
YOUTUBE_PRIVATE_UPLOAD_ENABLED=
YOUTUBE_UPLOAD_ENABLED=
PUBLIC_UPLOAD_ENABLED=false
RUN_YOUTUBE_PRIVATE_UPLOAD_SMOKE=
