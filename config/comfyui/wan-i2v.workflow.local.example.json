{
  "metadata": {
    "name": "wan-i2v-local-placeholder-commerce-shorts",
    "purpose": "Local-only placeholder for a user-exported ComfyUI Wan I2V workflow.",
    "live_execution": false,
    "notes": "Copy to wan-i2v.workflow.local.json and replace this placeholder with the user's exported ComfyUI workflow before a separately approved local smoke."
  },
  "nodes": {
    "positive_prompt": {
      "class_type": "WanI2VPositivePromptPlaceholder",
      "inputs": {
        "text": "{{PROMPT}}"
      }
    },
    "negative_prompt": {
      "class_type": "WanI2VNegativePromptPlaceholder",
      "inputs": {
        "text": "{{NEGATIVE_PROMPT}}"
      }
    },
    "source_image": {
      "class_type": "WanI2VSourceImagePlaceholder",
      "inputs": {
        "path": "{{SOURCE_IMAGE_PATH}}"
      }
    },
    "motion_settings": {
      "class_type": "WanI2VMotionSettingsPlaceholder",
      "inputs": {
        "seed": "{{SEED}}",
        "duration_seconds": "{{DURATION_SECONDS}}",
        "width": "{{WIDTH}}",
        "height": "{{HEIGHT}}"
      }
    },
    "video_output": {
      "class_type": "WanI2VVideoOutputPlaceholder",
      "inputs": {
        "filename_prefix": "{{OUTPUT_PREFIX}}"
      }
    }
  }
}
